generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  GERENTE
  EMPLEADO
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskCategory {
  DESARROLLO
  DISENO
  TESTING
  DOCUMENTACION
  OTRO
}

enum OrganizationUserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  passwordHash String
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  userRoles            UserRole[]
  sessions             Session[]
  tasksDesignatedTo    Task[]             @relation("DesignatedTo")
  tasksDesignatedBy    Task[]             @relation("DesignatedBy")
  managedProjects      Project[]          @relation("ProjectManager")
  projectsCreated      Project[]          @relation("ProjectCreator")
  organizationUsers    OrganizationUser[]
  organizationsCreated Organization[]     @relation("OrganizationCreator")
  organizationsUpdated Organization[]     @relation("OrganizationUpdater")
  taskComments         TaskComment[]
}

model Task {
  id               Int           @id @default(autoincrement())
  title            String
  description      String?
  status           TaskStatus    @default(PENDING)
  priority         TaskPriority  @default(MEDIUM)
  category         TaskCategory  @default(OTRO)
  designatedTo     Int?
  designatedBy     Int?
  designatedToUser User?         @relation("DesignatedTo", fields: [designatedTo], references: [id])
  designatedByUser User?         @relation("DesignatedBy", fields: [designatedBy], references: [id])
  project          Project?      @relation(fields: [projectId], references: [id])
  projectId        Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  deadline         DateTime?

  /// Soft delete; las queries de negocio deben filtrar deletedAt: null
  deletedAt        DateTime?

  taskComments TaskComment[]

  @@index([designatedTo])
  @@index([designatedBy])
  @@index([projectId])
  @@index([deletedAt])
  @@index([status])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRole {
  userId Int
  role   Role
  user   User @relation(fields: [userId], references: [id])

  /// Cuándo se otorgó este rol de aplicación
  assignedAt DateTime @default(now())

  @@id([userId, role])
}

model Organization {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  createdByUserId Int
  createdByUser   User @relation("OrganizationCreator", fields: [createdByUserId], references: [id])

  updatedByUserId Int?
  updatedByUser   User? @relation("OrganizationUpdater", fields: [updatedByUserId], references: [id])

  deletedAt DateTime?

  projects Project[]

  organizationUsers OrganizationUser[]

  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedAt])
}

model OrganizationUser {
  id               Int              @id @default(autoincrement())
  organizationId   Int
  organization     Organization     @relation(fields: [organizationId], references: [id])
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  role             OrganizationUserRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Project {
  id             Int          @id @default(autoincrement())
  name           String
  description    String?
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  managerId Int
  manager   User @relation("ProjectManager", fields: [managerId], references: [id])

  createdByUserId Int?
  createdByUser   User? @relation("ProjectCreator", fields: [createdByUserId], references: [id])

  deletedAt DateTime?

  tasks Task[]

  @@index([organizationId])
  @@index([createdAt])
  @@index([managerId])
  @@index([createdByUserId])
  @@index([deletedAt])
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  content   String
  taskId    Int
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  deletedAt DateTime?

  @@index([taskId])
  @@index([userId])
  @@index([deletedAt])
}
