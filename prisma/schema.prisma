generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                @id @default(autoincrement())
  name                 String
  email                String             @unique
  passwordHash         String
  avatarUrl            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @default(now()) @updatedAt
  organizationsCreated Organization[]     @relation("OrganizationCreator")
  organizationsUpdated Organization[]     @relation("OrganizationUpdater")
  organizationUsers    OrganizationUser[]
  projectsCreated      Project[]          @relation("ProjectCreator")
  managedProjects      Project[]          @relation("ProjectManager")
  sessions             Session[]
  tasksCreated         Task[]             @relation("CreatedBy")
  tasksDesignatedBy    Task[]             @relation("DesignatedBy")
  tasksDesignatedTo    Task[]             @relation("DesignatedTo")
  taskComments         TaskComment[]
  userRoles            UserRole[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRole {
  userId     Int
  role       Role
  /// Cuándo se otorgó este rol de aplicación
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, role])
}

model Organization {
  id                Int                @id @default(autoincrement())
  name              String
  description       String?
  updatedAt         DateTime           @default(now()) @updatedAt
  createdAt         DateTime           @default(now())
  createdByUserId   Int
  deletedAt         DateTime?
  updatedByUserId   Int?
  createdByUser     User               @relation("OrganizationCreator", fields: [createdByUserId], references: [id])
  updatedByUser     User?              @relation("OrganizationUpdater", fields: [updatedByUserId], references: [id])
  organizationUsers OrganizationUser[]
  projects          Project[]

  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([deletedAt])
}

model OrganizationUser {
  id             Int                  @id @default(autoincrement())
  organizationId Int
  userId         Int
  role           OrganizationUserRole @default(MEMBER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now()) @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Project {
  id              Int           @id @default(autoincrement())
  name            String
  description     String?
  organizationId  Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  managerId       Int
  createdByUserId Int?
  deletedAt       DateTime?
  status          ProjectStatus @default(ACTIVE)
  createdByUser   User?         @relation("ProjectCreator", fields: [createdByUserId], references: [id])
  manager         User          @relation("ProjectManager", fields: [managerId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])
  tasks           Task[]

  @@index([organizationId])
  @@index([createdAt])
  @@index([managerId])
  @@index([createdByUserId])
  @@index([deletedAt])
}

model Task {
  id               Int           @id @default(autoincrement())
  title            String
  description      String?
  status           TaskStatus    @default(PENDING)
  category         TaskCategory  @default(OTRO)
  createdAt        DateTime      @default(now())
  deadline         DateTime?
  designatedBy     Int?
  designatedTo     Int?
  priority         TaskPriority  @default(MEDIUM)
  projectId        Int?
  updatedAt        DateTime      @default(now()) @updatedAt
  /// Soft delete; las queries de negocio deben filtrar deletedAt: null
  deletedAt        DateTime?
  createdBy        Int
  createdByUser    User          @relation("CreatedBy", fields: [createdBy], references: [id])
  designatedByUser User?         @relation("DesignatedBy", fields: [designatedBy], references: [id])
  designatedToUser User?         @relation("DesignatedTo", fields: [designatedTo], references: [id])
  project          Project?      @relation(fields: [projectId], references: [id])
  taskComments     TaskComment[]

  @@index([designatedTo])
  @@index([designatedBy])
  @@index([projectId])
  @@index([deletedAt])
  @@index([status])
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  content   String
  taskId    Int
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  task      Task      @relation(fields: [taskId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([deletedAt])
}

enum Role {
  DIRECTOR
  GERENTE
  EMPLEADO
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskCategory {
  DESARROLLO
  DISENO
  TESTING
  DOCUMENTACION
  OTRO
}

enum OrganizationUserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
  PAUSED
  CANCELLED
  COMPLETED
}
